<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="8dp" android:layout_marginVertical="4dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="10dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
<TextView android:id="@+id/tvPair" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" android:fontFamily="monospace"/>
<TextView android:id="@+id/tvDir" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
<TextView android:id="@+id/tvGrade" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginEnd="8dp"/>
<TextView android:id="@+id/tvResult" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textStyle="bold"/>
</LinearLayout>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
<TextView android:id="@+id/tvConf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent" android:textSize="11sp" android:fontFamily="monospace" android:layout_marginEnd="12dp"/>
<TextView android:id="@+id/tvSession" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/text_secondary" android:textSize="11sp"/>
<TextView android:id="@+id/tvTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="monospace"/>
</LinearLayout>
<TextView android:id="@+id/tvNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginBottom="6dp" android:visibility="gone"/>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
<Button android:id="@+id/btnWin" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="✅ WIN" android:textSize="11sp" android:layout_marginEnd="4dp" app:backgroundTint="@color/buy_bg" android:textColor="@color/signal_buy" style="@style/Widget.MaterialComponents.Button"/>
<Button android:id="@+id/btnLoss" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="❌ LOSS" android:textSize="11sp" android:layout_marginEnd="4dp" app:backgroundTint="@color/sell_bg" android:textColor="@color/signal_sell" style="@style/Widget.MaterialComponents.Button"/>
<Button android:id="@+id/btnDelete" android:layout_width="36dp" android:layout_height="32dp" android:text="🗑" android:textSize="13sp" android:padding="0dp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
</LinearLayout>
</LinearLayout></com.google.android.material.card.MaterialCardView>