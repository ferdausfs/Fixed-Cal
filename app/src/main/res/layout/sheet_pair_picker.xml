<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@color/surface">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Pair" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:padding="16dp"/>
<EditText android:id="@+id/etSearch" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Search pair..." android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:background="@color/background" android:padding="12dp" android:inputType="textNoSuggestions" android:layout_marginStart="12dp" android:layout_marginEnd="12dp" android:layout_marginBottom="8dp"/>
<HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none" android:layout_marginBottom="8dp">
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp">
<TextView android:id="@+id/tabAll" android:layout_width="wrap_content" android:layout_height="34dp" android:gravity="center" android:text="All" android:textSize="12sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColor="@color/accent" android:layout_marginEnd="4dp"/>
<TextView android:id="@+id/tabFx" android:layout_width="wrap_content" android:layout_height="34dp" android:gravity="center" android:text="Forex" android:textSize="12sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColor="@color/text_secondary" android:layout_marginEnd="4dp"/>
<TextView android:id="@+id/tabCrypto" android:layout_width="wrap_content" android:layout_height="34dp" android:gravity="center" android:text="Crypto" android:textSize="12sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColor="@color/text_secondary" android:layout_marginEnd="4dp"/>
<TextView android:id="@+id/tabOtc" android:layout_width="wrap_content" android:layout_height="34dp" android:gravity="center" android:text="OTC" android:textSize="12sp" android:paddingStart="14dp" android:paddingEnd="14dp" android:textColor="@color/text_secondary"/>
</LinearLayout></HorizontalScrollView>
<ListView android:id="@+id/lvPairs" android:layout_width="match_parent" android:layout_height="320dp" android:divider="@color/stroke" android:dividerHeight="1dp"/>
</LinearLayout>