<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp" android:background="@color/surface">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️ App Settings" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Worker URL, connection config" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginBottom="16dp"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="API Base URL" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginBottom="6dp"/>
<EditText android:id="@+id/etApiUrl" android:layout_width="match_parent" android:layout_height="48dp" android:inputType="textUri" android:textColor="@color/text_primary" android:textSize="13sp" android:background="@color/background" android:padding="12dp" android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠ No trailing slash. Base URL only." android:textColor="@color/text_secondary" android:textSize="10sp" android:layout_marginBottom="16dp"/>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
<Button android:id="@+id/btnSettingsCancel" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="Cancel" android:layout_marginEnd="6dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
<Button android:id="@+id/btnSettingsSave" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="Save" app:backgroundTint="@color/accent"/>
</LinearLayout>
<Button android:id="@+id/btnSettingsReset" android:layout_width="match_parent" android:layout_height="44dp" android:text="Reset to Default" android:textColor="@color/signal_sell" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
</LinearLayout>