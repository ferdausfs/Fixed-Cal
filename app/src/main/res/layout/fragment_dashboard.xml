<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/swipeRefresh" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">
<FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
<ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
<TextView android:id="@+id/tvError" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:padding="24dp" android:textColor="@color/signal_sell" android:visibility="gone"/>
<ScrollView android:id="@+id/scrollContent" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SERVER" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
<TextView android:id="@+id/tvServerStatus" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="● CHECKING..." android:textSize="15sp" android:textStyle="bold"/>
<TextView android:id="@+id/tvServerVersion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="monospace"/>
</LinearLayout>
<TextView android:id="@+id/tvApiKeys" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="4dp"/>
</LinearLayout></com.google.android.material.card.MaterialCardView>
<com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SESSION" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<TextView android:id="@+id/tvSession" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="—" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
<TextView android:id="@+id/tvSessionQuality" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="—" android:textSize="12sp"/>
<TextView android:id="@+id/tvNewsBlackout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@color/sell_bg" android:padding="8dp" android:textColor="@color/signal_sell" android:textSize="12sp" android:textStyle="bold" android:visibility="gone"/>
</LinearLayout></com.google.android.material.card.MaterialCardView>
<com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MARKETS" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="10dp">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FOREX" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<TextView android:id="@+id/tvForexStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="3dp"/>
</LinearLayout>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CRYPTO" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<TextView android:id="@+id/tvCryptoStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="3dp"/>
</LinearLayout>
</LinearLayout></LinearLayout></com.google.android.material.card.MaterialCardView>
<com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FILTERS" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="10dp">
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
<TextView android:id="@+id/tvMinConfidence" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/accent" android:textSize="18sp" android:textStyle="bold"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min Conf" android:textColor="@color/text_secondary" android:textSize="10sp"/>
</LinearLayout>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
<TextView android:id="@+id/tvVolumeSpike" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/accent" android:textSize="18sp" android:textStyle="bold"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vol Spike" android:textColor="@color/text_secondary" android:textSize="10sp"/>
</LinearLayout>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
<TextView android:id="@+id/tvNewsMargin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/accent" android:textSize="18sp" android:textStyle="bold"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="News Margin" android:textColor="@color/text_secondary" android:textSize="10sp"/>
</LinearLayout>
</LinearLayout></LinearLayout></com.google.android.material.card.MaterialCardView>
<com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke" app:strokeWidth="1dp">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INDICATORS" android:textColor="@color/text_secondary" android:textSize="10sp"/>
<TextView android:id="@+id/tvIndicatorCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="—" android:textColor="@color/text_primary" android:textSize="14sp"/>
</LinearLayout></com.google.android.material.card.MaterialCardView>
</LinearLayout></ScrollView></FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>